{
  "default_provider": "google",
  "providers": {
    "dashscope": {
      "features": { "thinking": false, "reasoningEffort": [], "customModel": true },
      "defaults": { "temperature": 0.7, "top_p": 0.8 },
      "default_model": "qwen-plus",
      "models": {
        "qwen-plus": {},
        "qwen-turbo": {},
        "deepseek-r1": {}
      }
    },
    "google": {
      "features": { "thinking": false, "reasoningEffort": [], "customModel": true },
      "defaults": { "temperature": 1.0, "top_p": 0.8, "top_k": 20 },
      "default_model": "gemini-2.5-flash",
      "models": {
        "gemini-2.5-flash": {},
        "gemini-2.5-flash-lite": {},
        "gemini-2.5-pro": {}
      }
    },
    "openai": {
      "features": { "thinking": true, "reasoningEffort": ["low", "medium", "high", "xhigh"], "customModel": true },
      "defaults": { "thinking": true, "reasoning_effort": "medium", "max_tokens": 65536 },
      "default_model": "gpt-5.4-mini",
      "models": {
        "gpt-5.5": { "reasoning_effort": "medium", "max_tokens": 65536 },
        "gpt-5.4": { "reasoning_effort": "medium", "max_tokens": 65536 },
        "gpt-5.4-mini": { "reasoning_effort": "medium", "max_tokens": 65536 },
        "gpt-5.4-nano": { "thinking": false, "temperature": 1.0, "max_tokens": 16384 },
        "gpt-5": { "thinking": true, "reasoning_effort": "medium", "max_tokens": 32768 },
        "gpt-4.1": { "thinking": false, "temperature": 0.7, "top_p": 0.8, "max_tokens": 16384 },
        "gpt-4o": { "thinking": false, "temperature": 0.7, "top_p": 0.8, "max_tokens": 16384 }
      }
    },
    "openrouter": {
      "features": { "thinking": false, "reasoningEffort": [], "customModel": true },
      "defaults": { "temperature": 0.7, "top_p": 0.8 },
      "default_model": "openai/gpt-5-nano",
      "models": {
        "openai/gpt-5-nano": {},
        "openai/gpt-4o": {},
        "openai/gpt-4.1": {},
        "openai/o3": {},
        "deepseek/deepseek-r1": {},
        "anthropic/claude-3.7-sonnet": {},
        "anthropic/claude-3.5-sonnet": {}
      }
    },
    "ollama": {
      "features": { "thinking": false, "reasoningEffort": [], "customModel": true },
      "defaults": { "temperature": 0.7, "top_p": 0.8, "num_ctx": 32000 },
      "default_model": "qwen3:1.7b",
      "models": {
        "qwen3:1.7b": { "options": { "num_ctx": 32000 } },
        "llama3:8b": { "options": { "num_ctx": 8000 } },
        "qwen3:8b": { "options": { "num_ctx": 32000 } }
      }
    },
    "bedrock": {
      "features": { "thinking": true, "reasoningEffort": [], "thinkingAdaptive": true, "customModel": true },
      "defaults": { "temperature": 0.7, "max_tokens": 65536, "thinking": "adaptive" },
      "default_model": "us.anthropic.claude-sonnet-4-5-20250929-v1:0",
      "client_class": "BedrockClient",
      "models": {
        "us.anthropic.claude-sonnet-4-5-20250929-v1:0": { "max_tokens": 65536, "thinking": "adaptive" },
        "us.anthropic.claude-opus-4-5-20251101-v1:0": { "max_tokens": 65536, "thinking": "adaptive" },
        "us.anthropic.claude-haiku-4-5-20251001-v1:0": { "max_tokens": 16384 },
        "us.anthropic.claude-3-5-sonnet-20240620-v1:0": { "max_tokens": 4096 },
        "anthropic.claude-3-haiku-20240307-v1:0": { "max_tokens": 4096 },
        "anthropic.claude-3-opus-20240229-v1:0": { "max_tokens": 4096 }
      }
    },
    "azure": {
      "features": { "thinking": false, "reasoningEffort": [], "customModel": true },
      "defaults": { "temperature": 0.7, "top_p": 0.8 },
      "default_model": "gpt-4o",
      "client_class": "AzureAIClient",
      "models": {
        "gpt-4o": {},
        "gpt-4": {},
        "gpt-35-turbo": {},
        "gpt-4-turbo": {}
      }
    },
    "deepseek": {
      "features": { "thinking": true, "reasoningEffort": ["high", "max"], "customModel": true },
      "defaults": { "thinking": true, "reasoning_effort": "max", "max_tokens": 65536 },
      "default_model": "deepseek-v4-flash",
      "models": {
        "deepseek-v4-flash": {},
        "deepseek-v4-pro": {}
      }
    }
  }
}
